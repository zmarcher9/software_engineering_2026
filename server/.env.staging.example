# Staging environment template — copy the values here into Railway's
# "staging" environment variables (never into a committed .env file).
#
#   railway environment staging
#   railway variables --set "SUPABASE_URL=..." --set "SUPABASE_ANON_KEY=..." ...
#
# See scripts/setup-railway-staging.sh for an end-to-end script, and
# docs/staging-environment.md for the full walkthrough.

# Staging Supabase project (or persistent branch) — must NOT point at the
# production Supabase project. Project Settings → API on the staging project.
SUPABASE_URL=https://your-staging-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-staging-anon-key-here

# Use a secret distinct from production so staging and prod tokens are never
# interchangeable. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-staging-secret

# Railway auto-sets RAILWAY_ENVIRONMENT to the environment name (staging),
# which the app also checks. Setting ENVIRONMENT explicitly keeps this
# working the same way if you ever run the image outside Railway.
ENVIRONMENT=staging

SUPABASE_SSL_VERIFY=true

# Comma-separated exact origins allowed to call this API.
# Add your stable staging frontend URL here.
CORS_ORIGINS=https://flowfunds-staging.vercel.app

# Optional regex to also allow per-PR Vercel preview URLs, e.g.:
# CORS_ORIGIN_REGEX=^https://flowfunds-[a-z0-9-]+\.vercel\.app$
CORS_ORIGIN_REGEX=
