# From Supabase Dashboard → Project Settings → API (NOT the Database connection string)
# Use the Project URL only — do not append /rest/v1
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-long-anon-key-here

# Used to sign FlowFunds JWT session tokens. Replace with a long random value.
JWT_SECRET=replace-with-a-long-random-secret

# Use production in deployed environments so unsafe dev defaults are rejected.
ENVIRONMENT=development

# Set to false on school/corporate Wi-Fi if SSL verification fails locally
SUPABASE_SSL_VERIFY=true
